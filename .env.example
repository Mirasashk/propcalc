# PropCalc Environment Variables
# Copy this file to .env and fill in your Firebase config

# Firebase
FIREBASE_API_KEY=your_api_key_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_APP_ID_IOS=your_ios_app_id_here
FIREBASE_APP_ID_ANDROID=your_android_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here

# RevenueCat
REVENUECAT_API_KEY_IOS=your_ios_key_here
REVENUECAT_API_KEY_ANDROID=your_android_key_here

# AdMob
ADMOB_APP_ID_IOS=your_ios_admob_app_id_here
ADMOB_APP_ID_ANDROID=your_android_admob_app_id_here
